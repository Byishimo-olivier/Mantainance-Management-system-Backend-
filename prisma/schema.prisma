// --- Preventive & Routine Maintenance Extension ---

model Company {
  id                  String              @id @default(auto()) @map("_id") @db.ObjectId
  name                String              @unique
  email               String?             @unique
  phone               String?
  address             String?
  city                String?
  country             String?
  logo                String?
  industry            String?
  size                String?             // small, medium, large, enterprise
  
  // Subscription info
  subscriptions       Subscription[]      // All subscriptions for this company
  subscriptionStatus  String              @default("inactive") // inactive, trial, active, cancelled, suspended
  subscriptionPlan    String?             // basic, premium, professional, enterprise
  subscriptionStartDate DateTime?
  subscriptionEndDate DateTime?
  
  // Team management
  users               User[]              // All users in this company
  adminId             String?             @db.ObjectId // Primary account holder
  
  // Usage tracking
  totalUsers          Int                 @default(1)
  maxUsers            Int                 @default(999) // Seat limit based on plan
  
  metadata            Json?               // Additional company data
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
}

model Property {
  id                  String               @id @default(auto()) @map("_id") @db.ObjectId
  userId              String?              @db.ObjectId
  user                User?                @relation(fields: [userId], references: [id])
  name                String
  type                String
  address             String
  city                String?
  country             String?
  contactName         String?
  phone               String?
  email               String?
  status              String?              @default("Active")
  clientId            String?              @db.ObjectId
  beds                Int?
  baths               Int?
  area                Int?
  floors              Int?
  blocks              Json?
  block               String?
  rooms               Int?
  photos              String[]
  roomNames           Json?
  namedBlocks         Json?
  blocksModifiable    Boolean?            @default(false)
  includeMapCoordinates Boolean?          @default(false)
  // New Fields
  latitude            Float?
  longitude           Float?
  parentPropertyId    String?              @db.ObjectId
  parentProperty      Property?            @relation("PropertyToSubProperties", fields: [parentPropertyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subProperties       Property[]           @relation("PropertyToSubProperties")
  assignedWorkers     String[]             // List of worker IDs or names
  assignedTeam        String?
  vendors             Json?                // List of vendors
  customers           Json?                // List of customers
  customData          Json?                // [{ name: string, value: string, unit: string }]
  
  assets              Asset[]
  internalTechnicians InternalTechnician[]
  issues              Issue[]
  subscriptions       Subscription[]
  createdAt           DateTime             @default(now())
}

model Asset {
  id                  String             @id @default(auto()) @map("_id") @db.ObjectId
  propertyId          String?            @db.ObjectId
  property            Property?          @relation(fields: [propertyId], references: [id])
  userId              String?            @db.ObjectId
  user                User?              @relation(fields: [userId], references: [id])
  name                String
  type                String
  description         String?
  serialNumber        String?
  identifiers         Json? // e.g. { rfid: '...', barcode: '...', nfc: '...', qr: '...' }
  parentId            String?            @db.ObjectId
  assetTypeId         String?            @db.ObjectId
  location            Json? // e.g. { building: '', floor: '', room: '' }
  gps                 Json? // e.g. { lat: 0.0, lng: 0.0 }
  purchaseDate        DateTime?
  purchaseCost        Float?
  currentValue        Float?
  depreciationRate    Float?
  depreciationHistory Json?
  warrantyUntil       DateTime?
  vendorId            String?            @db.ObjectId
  vendorName          String?
  status              String             @default("Active")
  quantity            Int                @default(1)
  photos              String[]
  documents           String[]
  spareParts          SparePart[]
  movements           AssetMovementLog[] @relation("AssetToMovements")
  issues              Issue[]
  createdAt           DateTime           @default(now())
}

model InternalTechnician {
  id                   String                @id @default(auto()) @map("_id") @db.ObjectId
  propertyId           String?               @db.ObjectId
  property             Property?             @relation(fields: [propertyId], references: [id])
  userId               String?               @db.ObjectId
  user                 User?                 @relation(fields: [userId], references: [id])
  name                 String
  email                String?
  phone                String
  specialty            String[]
  rating               Float                 @default(0)
  completed            Int                   @default(0)
  status               String                @default("Active")
  maintenanceSchedules MaintenanceSchedule[]
  type                 String                @default("INTERNAL")
  createdAt            DateTime              @default(now())
}

model MaintenanceTemplate {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  type      String
  frequency String
  createdAt DateTime @default(now())
}

model AssetType {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?
  fields      Json? // custom template fields per asset type
  createdAt   DateTime @default(now())
}

model AssetMovementLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  assetId   String   @db.ObjectId
  asset     Asset    @relation("AssetToMovements", fields: [assetId], references: [id])
  from      Json?
  to        Json?
  movedBy   String?
  notes     String?
  timestamp DateTime @default(now())
}

model SparePart {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  assetId           String?  @db.ObjectId
  asset             Asset?   @relation(fields: [assetId], references: [id])
  name              String
  sku               String?
  quantity          Int      @default(0)
  unitCost          Float?
  lowStockThreshold Int?
  status            String   @default("Available")
  createdAt         DateTime @default(now())
}

model MaintenanceSchedule {
  id           String              @id @default(auto()) @map("_id") @db.ObjectId
  technicianId String?             @db.ObjectId
  technician   InternalTechnician? @relation(fields: [technicianId], references: [id])
  userId       String?             @db.ObjectId
  user         User?               @relation(fields: [userId], references: [id])
  name         String
  email        String
  employees    String
  company      String?
  phone        String?
  date         String
  time         String
  assets       String?
  // PM + WO metadata
  workOrderTitle       String?
  workOrderDescription String?
  priority             String?            @default("Medium")
  category             String?
  durationHours        Float?
  requiresSignature    Boolean?           @default(false)
  attachments          Json?
  tasks                Json?              // [{ title, status }]
  assetsRows           Json?              // [{ assetId, locationId, startDate, endDate, timezone, assignee }]
  assetsCount          Int?               @default(0)
  locationsCount       Int?               @default(0)
  timezone             String?
  scheduleType         String?            // calendar | meter | combined
  calendarRule         Json?              // { every: 1, unit: 'day', time: '22:00', leadDays: 0 }
  meterRule            Json?              // { operator: '>=', threshold: 100, unit: 'hours', dueAfter: { value:1, unit:'day' } }
  combinedRule         Json?
  // Routine scheduling fields
  routine      Boolean             @default(false)
  frequency    String?
  interval     Int?                @default(1)
  lastReminder DateTime?
  // Persistent per-schedule snooze (global)
  snoozedUntil DateTime?
  // Per-user dismissal map: { userId: timestamp }
  dismissedBy  Json?
  status       String
  block        String?
  rooms        String?
  floors       String?
  description  String
  nextDate     DateTime
  createdAt    DateTime            @default(now())
}

model MaintenanceReminderLog {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  scheduleId String   @db.ObjectId
  recipients Json
  method     String // 'script' | 'dashboard' | 'manual'
  sentAt     DateTime @default(now())
  createdAt  DateTime @default(now())
}

// Prisma schema for Maintenance Management System
// Update provider and credentials in .env as needed

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "mongodb"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

model User {
  id                   String                @id @default(auto()) @map("_id") @db.ObjectId
  name                 String
  phone                String                @unique
  email                String                @unique
  password             String
  role                 Role
  status               String
  
  // Company association
  companyId            String?               @db.ObjectId
  company              Company?              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  isCompanyAdmin       Boolean               @default(false) // Can manage team members
  
  createdAt            DateTime              @default(now())
  properties           Property[]
  assets               Asset[]
  internalTechnicians  InternalTechnician[]
  maintenanceSchedules MaintenanceSchedule[]

  @@map("users")
}

enum Role {
  admin
  manager
  technician
  client
}

model MaintenanceRequest {
  id                   String   @id @default(auto()) @map("_id") @db.ObjectId
  clientId             String
  issueType            String
  description          String
  priority             String
  status               String
  assignedTechnicianId String?
  createdAt            DateTime @default(now())
}

model JobEvidence {
  id           String       @id @default(auto()) @map("_id") @db.ObjectId
  requestId    String
  type         EvidenceType
  imageUrl     String
  uploadedById String
  createdAt    DateTime     @default(now())
}

enum EvidenceType {
  BEFORE
  DURING
  AFTER
}

model Material {
  id                String @id @default(auto()) @map("_id") @db.ObjectId
  name              String
  quantity          Int
  unitCost          Float
  supplier          String
  lowStockThreshold Int
}

model MaterialRequest {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  technicianId       String
  requestId          String
  status             String
  description        String?
  urgency            String?
  technicianName     String?
  issueId            String?
  forwardedToClient  Boolean  @default(false)
  clientId           String?
  clientResponse     String?
  createdAt          DateTime? @default(now())
}

model MaterialRequestItem {
  id                String @id @default(auto()) @map("_id") @db.ObjectId
  materialId        String
  quantity          Int
  materialRequestId String
}

model Procurement {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  supplier   String
  totalCost  Float
  invoiceUrl String
  createdAt  DateTime @default(now())
}

model Subscription {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  
  // Company-level subscription (not individual user)
  companyId        String?  @db.ObjectId
  company          Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  // Subscription details
  propertyId       String?  @db.ObjectId
  property         Property? @relation(fields: [propertyId], references: [id])
  email            String
  plan             String   // basic, premium, professional, enterprise
  billingCycle     String   @default("monthly") // weekly, monthly, yearly
  amount           Float    // Amount for current billing cycle
  status           String   @default("active") // active, cancelled, paused, pending
  startDate        DateTime @default(now())
  endDate          DateTime?
  nextBillingDate  DateTime
  cancelledAt      DateTime?
  credentialHash   String? // Hash for security
  features         String[] // Array of enabled features
  paymentMethod    String? // pesapal, card, bank_transfer, etc
  paymentStatus    String @default("pending") // pending, paid, failed, refunded
  autoRenew        Boolean @default(true)
  
  // Relations
  invoices         Invoice[]
  payments         Payment[]
  metadata         Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Payment {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  subscriptionId   String   @db.ObjectId
  subscription     Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  amount           Float
  currency         String @default("USD")
  status           String // pending, completed, failed, refunded
  paymentMethod    String // card, bank_transfer, paypal, etc
  transactionId    String? @unique
  description      String?
  paidAt           DateTime?
  failureReason    String?
  metadata         Json? // Additional payment details
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Invoice {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  subscriptionId   String   @db.ObjectId
  subscription     Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  invoiceNumber    String   @unique
  amount           Float
  billingCycle     String // weekly, monthly, yearly
  period           String // "Jan 2026 - Feb 2026" format
  status           String @default("unpaid") // unpaid, paid, overdue, cancelled
  dueDate          DateTime
  paidAt           DateTime?
  notes            String?
  pdf              String? // URL to PDF invoice
  metadata         Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Technician {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  email          String   @unique
  phone          String
  specialization String[]
  rating         Float    @default(0)
  completed      Int      @default(0)
  status         String   @default("Active")
  type           String   @default("EXTERNAL")
  password       String?
}

model Issue {
  rejected        Boolean   @default(false)
  rejectedAt      DateTime?
  rejectionReason String?
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  companyName     String?
  title           String
  description     String
  location        String
  propertyId      String?   @db.ObjectId
  property        Property? @relation(fields: [propertyId], references: [id])
  assetId         String?   @db.ObjectId
  asset           Asset?    @relation(fields: [assetId], references: [id])
  tags            String[]
  assignees       Json
  overdue         Boolean   @default(false)
  time            String
  photo           String?
  userId          String? // who posted the issue (authenticated user)
  anonId          String? // anonymous submission ID
  submissionType  String    @default("authenticated") // "authenticated" or "anonymous"
  name            String? // contact name (for both auth and anon)
  email           String? // contact email (for both auth and anon)
  phone           String? // contact phone (for both auth and anon)
  assignedTo      String? // technician assigned
  inspectorId     String?  @db.ObjectId // authenticated client inspector id
  requestorId     String?  // anonymous requestor id/token
  address         String?
  beforeImage     String?
  afterImage      String?
  fixTime         String?
  fixDeadline     DateTime?
  priority        String?   @default("MEDIUM")
  frequency       String?
  status          String?
  approved        Boolean   @default(false)
  approvedAt      DateTime?
  resubmitted     Boolean   @default(false)
  resubmittedAt   DateTime?
  resubmittedBy   String?
  category        String?
  assetName       String?
  team            String?
  additionalResponsibleWorkers Json?
  checklist       Json?
  estimatedTime   Float?
  signature       String?
  chat            Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model TechnicianInvite {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  technicianId  String?  @db.ObjectId
  email         String
  token         String   @unique
  used          Boolean  @default(false)
  expiresAt     DateTime?
  createdAt     DateTime @default(now())
}

model Feedback {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  message        String
  date           DateTime @default(now())
  issueId        String
  technicianId   String
  clientId       String
  // Optionally, store technician and client names for easier frontend display
  technicianName String?
  clientName     String?
  issueTitle     String?
}

model Manager {
  id    String @id @default(auto()) @map("_id") @db.ObjectId
  name  String
  email String @unique
}

model Notification {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  title     String
  message   String
  type      String   @default("info") // info, success, warning, error
  read      Boolean  @default(false)
  link      String?  // Optional URL to navigate to
  createdAt DateTime @default(now())
}

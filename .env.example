# Frontend / callback URLs
FRONTEND_URL=https://your-frontend-domain.com

# PesaPal card payments
PESAPAL_ENV=sandbox
PesaPal_Consumer_Key=your_pesapal_consumer_key
PesaPal_Consumer_Secret=your_pesapal_consumer_secret
PESAPAL_CALLBACK_URL=https://your-backend-domain.com/api/subscriptions/payments/pesapal-callback

# InTouchPay mobile money collections
INTOUCHPAY_BASE_URL=https://www.intouchpay.co.rw
INTOUCHPAY_USERNAME=your_intouchpay_username
INTOUCHPAY_ACCOUNT_NO=your_intouchpay_account_number
INTOUCHPAY_PARTNER_PASSWORD=your_intouchpay_partner_password
INTOUCHPAY_CALLBACK_URL=https://your-backend-domain.com/api/subscriptions/payments/mobile-money-callback

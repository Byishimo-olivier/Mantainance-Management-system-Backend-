{
  "name": "mms-backend",
  "version": "1.0.0",
  "main": "src/index.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "build": "prisma generate",
    "postinstall": "prisma generate",
    "prisma": "prisma",
    "send:monthly-reports": "node scripts/send-monthly-reports.js",
    "install-parsers": "npm install xlsx pdf-parse mammoth tesseract.js csv-parse --save-optional",

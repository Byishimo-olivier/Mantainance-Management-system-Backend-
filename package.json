    "repair-data": "node scripts/repair-data-mongoose.js",
    "setup:mtn-collection": "node scripts/setup-mtn-collection.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^6.5.0",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^9.1.3",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.12"
  },
  "optionalDependencies": {
    "csv-parse": "^5.6.0",
    "mammoth": "^1.11.0",
    "pdf-parse": "^1.1.4",
    "tesseract.js": "^4.1.4",
